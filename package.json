{
  "name": "discord-news-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Discord news bot MVP built as an extensible event pipeline.",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "ingest:test": "npm run build && node scripts/ingest-fixture.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test:storage": "node --import tsx --test tests/storage.test.ts",
    "test:bot": "node --import tsx --test tests/bot.test.ts",
    "test:all": "node --import tsx --test tests/storage.test.ts tests/scoring.test.ts tests/bot.test.ts tests/polling.test.ts",
    "test": "npm run test:all"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
