generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id          String
  url         String?
  urlHash     String?
  title       String
  titleHash   String?
  topic       String
  source      String
  publishedAt DateTime?
  firstSeenAt DateTime  @default(now())
  postedAt    DateTime?
  score       Int?
  status      String    @default("INDEXED")
  statusReason String?
  rawJson     String?

  discordMessageId String?
  discordChannelId String?
  userFavorites UserFavorite[]
  emailForwards EmailForward[]

  @@id([id, topic])
  @@index([topic])
  @@index([urlHash])
  @@index([titleHash])
  @@index([postedAt])
  @@index([status])
  @@index([discordMessageId])
}

model UserFavorite {
  id               String   @id @default(uuid())
  userId           String   // Discord User ID
  articleId        String
  articleTopic     String
  article          Article  @relation(fields: [articleId, articleTopic], references: [id, topic], onDelete: Cascade)
  discordChannelId String
  discordMessageId String
  savedAt          DateTime @default(now())
  instapaperStatus String   // "SUCCESS", "FAILED", "SKIPPED"

  @@unique([userId, articleId, articleTopic])
  @@index([userId])
  @@index([savedAt])
}

model EmailForward {
  id               String   @id @default(uuid())
  userId           String   // Discord User ID
  articleId        String
  articleTopic     String
  article          Article  @relation(fields: [articleId, articleTopic], references: [id, topic], onDelete: Cascade)
  discordChannelId String
  discordMessageId String
  recipientEmail   String
  status           String   // "SUCCESS", "FAILED", "PENDING"
  error            String?
  createdAt        DateTime @default(now())

  @@unique([userId, articleId, articleTopic])
  @@index([userId])
  @@index([createdAt])
}

model CurationLog {
  id        String   @id @default(uuid())
  title     String
  url       String?
  source    String
  topic     String
  status    String   // "POSTED", "SKIPPED_THRESHOLD", "SKIPPED_BLOCKED", "DEFERRED_COOLDOWN"
  score     Int
  breakdown String   // Stringified JSON array of reasons
  createdAt DateTime @default(now())

  @@index([topic])
  @@index([status])
  @@index([createdAt])
}



