generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id          String
  url         String?
  urlHash     String?
  title       String
  titleHash   String?
  topic       String
  source      String
  publishedAt DateTime?
  firstSeenAt DateTime  @default(now())
  postedAt    DateTime?
  score       Int?
  status      String    @default("INDEXED")
  statusReason String?
  intent      String?
  intentConfidence Float?
  route       String?
  routeReason String?
  rawJson     String?

  discordMessageId String?
  discordChannelId String?
  userFavorites UserFavorite[]
  emailForwards EmailForward[]

  storyId          String?
  story            Story?     @relation(fields: [storyId], references: [id], onDelete: SetNull)
  signals          StorySignal[]

  @@id([id, topic])
  @@index([topic])
  @@index([urlHash])
  @@index([titleHash])
  @@index([postedAt])
  @@index([status])
  @@index([intent])
  @@index([route])
  @@index([discordMessageId])
  @@index([storyId])
}

model UserFavorite {
  id               String   @id @default(uuid())
  userId           String   // Discord User ID
  articleId        String
  articleTopic     String
  article          Article  @relation(fields: [articleId, articleTopic], references: [id, topic], onDelete: Cascade)
  discordChannelId String
  discordMessageId String
  savedAt          DateTime @default(now())
  instapaperStatus String   // "SUCCESS", "FAILED", "SKIPPED"

  @@unique([userId, articleId, articleTopic])
  @@index([userId])
  @@index([savedAt])
}

model EmailForward {
  id               String   @id @default(uuid())
  userId           String   // Discord User ID
  articleId        String
  articleTopic     String
  article          Article  @relation(fields: [articleId, articleTopic], references: [id, topic], onDelete: Cascade)
  discordChannelId String
  discordMessageId String
  recipientEmail   String
  status           String   // "SUCCESS", "FAILED", "PENDING"
  error            String?
  createdAt        DateTime @default(now())

  @@unique([userId, articleId, articleTopic])
  @@index([userId])
  @@index([createdAt])
}

model CurationLog {
  id        String   @id @default(uuid())
  title     String
  url       String?
  source    String
  topic     String
  status    String   // "POSTED", "SKIPPED_THRESHOLD", "SKIPPED_BLOCKED", "DEFERRED_COOLDOWN"
  score     Int
  breakdown String   // Stringified JSON array of reasons
  createdAt DateTime @default(now())

  @@index([topic])
  @@index([status])
  @@index([createdAt])
}




model Event {
  id              String   @id @default(uuid())
  topic           String
  title           String
  discordThreadId String?
  indexMessageId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  stories         Story[]

  @@index([topic])
}

model Story {
  id               String   @id @default(uuid())
  eventId          String?
  event            Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  topic            String
  title            String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  status           String   @default("OPEN") // OPEN, MERGED, CLOSED
  mergedIntoId     String?
  mergedInto       Story?   @relation("MergedStory", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom       Story[]  @relation("MergedStory")
  
  discordThreadId  String?
  lastActivityAt   DateTime @default(now())

  articles         Article[]
  signals          StorySignal[]

  @@index([topic])
  @@index([status])
}

model StorySignal {
  id          String   @id @default(uuid())
  storyId     String?
  story       Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  articleId   String?
  articleTopic String?
  article     Article? @relation(fields: [articleId, articleTopic], references: [id, topic], onDelete: Cascade)
  
  type        String   // "ENTITY", "CUE"
  value       String   // e.g., "LeBron James", "trade"
  weight      Float    @default(1.0)

  @@index([storyId])
  @@index([articleId, articleTopic])
  @@index([type, value])
}

model LlmReviewLog {
  id          String   @id @default(uuid())
  topic       String
  actionType  String   // "MERGE", "SPLIT", "REASSIGN", "CREATE_STORY", "CREATE_EVENT"
  targetId    String
  targetType  String   // "STORY", "EVENT", "ARTICLE"
  confidence  Float
  reason      String
  createdAt   DateTime @default(now())

  @@index([topic])
  @@index([actionType])
  @@index([createdAt])
}
